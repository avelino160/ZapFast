# ====================================
# PILOTZAP ENVIRONMENT CONFIGURATION
# ====================================

# Database Configuration
# Neon PostgreSQL Database URL
# Formato: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://your_user:your_password@your_host/your_database?sslmode=require

# Session Configuration
# Use uma string aleatória segura para produção
SESSION_SECRET=your-secure-session-secret-here

# Environment
# Valores: development, production, test
NODE_ENV=development

# Server Configuration
PORT=5000

# ====================================
# WHATSAPP CONFIGURATION
# ====================================
WHATSAPP_WEBHOOK_URL=
WHATSAPP_SESSION_PATH=./auth_info

# ====================================
# OPENAI CONFIGURATION
# ====================================
# OpenAI API Key para Chatbot AI
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ====================================
# PUSH NOTIFICATIONS (VAPID KEYS)
# ====================================
# Generate using: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_SUBJECT=mailto:your-email@domain.com

# ====================================
# WEBHOOK SECRETS (INTEGRAÇÕES)
# ====================================
# Stripe
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Mercado Pago
MERCADOPAGO_SECRET=your_mercadopago_webhook_secret

# SendGrid
SENDGRID_WEBHOOK_SECRET=your_sendgrid_webhook_secret

# Mailgun
MAILGUN_WEBHOOK_SECRET=your_mailgun_webhook_secret

# Twilio
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# HubSpot
HUBSPOT_SECRET=your_hubspot_webhook_secret

# Pipedrive
PIPEDRIVE_SECRET=your_pipedrive_webhook_secret

# ====================================
# ADMIN CONFIGURATION
# ====================================
# Admin access secret (para funcionalidades administrativas)
ADMIN_SECRET=your-admin-secret-key

# ====================================
# DOMAIN CONFIGURATION
# ====================================
# Domain used for referral links and callbacks
DOMAIN=pilotzap.tech
FRONTEND_URL=https://pilotzap.tech
BACKEND_URL=https://api.pilotzap.tech